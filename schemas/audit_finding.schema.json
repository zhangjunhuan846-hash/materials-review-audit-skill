{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditFinding",
  "type": "object",
  "required": [
    "finding_id",
    "severity",
    "category",
    "message",
    "recommended_action"
  ],
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "P0",
        "P1",
        "P2"
      ]
    },
    "category": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "evidence": {
      "type": "object"
    },
    "recommended_action": {
      "type": "string"
    }
  }
}